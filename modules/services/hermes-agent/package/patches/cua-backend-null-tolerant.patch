+def _safe_int(value: Any, default: Optional[int] = None) -> Optional[int]:
+    """Best-effort int conversion for partial driver metadata."""
+    if value is None:
+        return default
+    try:
+        return int(value)
+    except (TypeError, ValueError):
+        return default
